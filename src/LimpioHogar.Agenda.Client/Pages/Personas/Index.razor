@page "/personas"
@attribute [Authorize]
@inject NavigationManager Nav

<PageTitle>LimpioHogar - Personas</PageTitle>

<div style="min-height:100vh;background:white;font-family:'Inter',sans-serif;">
    <div style="padding:24px;">
        <h1 style="font-size:1.5rem;color:#1E2D4E;margin:0 0 24px 0;">Personas</h1>

        <div style="display:flex;gap:12px;">
            <button @onclick="@(() => Nav.NavigateTo("/trabajadoras"))"
                    style="flex:1;display:flex;flex-direction:column;align-items:center;gap:8px;padding:24px 16px;background:#F5F7FA;border:2px solid transparent;border-radius:12px;cursor:pointer;transition:all 0.2s;"
                    onmouseover="this.style.borderColor='#4CAF9A'"
                    onmouseout="this.style.borderColor='transparent'">
                <div style="width:56px;height:56px;border-radius:12px;background:#1E2D4E;display:flex;align-items:center;justify-content:center;">
                    <MudIcon Icon="@Icons.Material.Filled.CleaningServices" Style="color:#4CAF9A;font-size:28px;" />
                </div>
                <span style="font-size:0.9rem;font-weight:500;color:#1E2D4E;">Trabajadoras</span>
            </button>

            <button @onclick="@(() => Nav.NavigateTo("/clientes"))"
                    style="flex:1;display:flex;flex-direction:column;align-items:center;gap:8px;padding:24px 16px;background:#F5F7FA;border:2px solid transparent;border-radius:12px;cursor:pointer;transition:all 0.2s;"
                    onmouseover="this.style.borderColor='#4CAF9A'"
                    onmouseout="this.style.borderColor='transparent'">
                <div style="width:56px;height:56px;border-radius:12px;background:#1E2D4E;display:flex;align-items:center;justify-content:center;">
                    <MudIcon Icon="@Icons.Material.Filled.Groups" Style="color:#4CAF9A;font-size:28px;" />
                </div>
                <span style="font-size:0.9rem;font-weight:500;color:#1E2D4E;">Clientes</span>
            </button>
        </div>
    </div>
</div>
