@page "/login"
@layout LimpioHogar.Agenda.Client.Layout.LoginLayout
@attribute [AllowAnonymous]

<PageTitle>LimpioHogar - Ingresar</PageTitle>

<div style="display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;max-width:390px;margin:0 auto;padding:0 24px;background:white;font-family:'Inter',sans-serif;">
    <div style="width:100%;max-width:360px;">
        <!-- Logo -->
        <div style="display:flex;flex-direction:column;align-items:center;margin-bottom:48px;">
            <div style="width:80px;height:80px;border-radius:16px;background:#1E2D4E;display:flex;align-items:center;justify-content:center;margin-bottom:16px;">
                <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Style="color:#4CAF9A;font-size:40px;" />
            </div>
            <h1 style="font-size:1.875rem;color:#1E2D4E;font-weight:600;margin:0;">LimpioHogar</h1>
            <p style="font-size:0.875rem;color:#6B7280;margin-top:4px;">Agenda</p>
        </div>

        <!-- Form -->
        <EditForm Model="@_loginModel" OnValidSubmit="HandleLogin" FormName="login">
            <div style="margin-bottom:16px;">
                <label style="display:block;font-size:0.875rem;color:#374151;margin-bottom:8px;">Email</label>
                <input type="email" @bind="_loginModel.Email"
                       style="width:100%;padding:12px 16px;border-radius:8px;background:#F5F7FA;border:2px solid transparent;outline:none;font-size:0.875rem;box-sizing:border-box;"
                       placeholder="tu@email.com" required />
            </div>

            <div style="margin-bottom:24px;">
                <label style="display:block;font-size:0.875rem;color:#374151;margin-bottom:8px;">Contrasena</label>
                <input type="password" @bind="_loginModel.Password"
                       style="width:100%;padding:12px 16px;border-radius:8px;background:#F5F7FA;border:2px solid transparent;outline:none;font-size:0.875rem;box-sizing:border-box;"
                       placeholder="********" required />
            </div>

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div style="background:#FEE2E2;color:#DC2626;padding:12px;border-radius:8px;font-size:0.875rem;margin-bottom:16px;">
                    @_errorMessage
                </div>
            }

            <button type="submit" disabled="@_loading"
                    style="width:100%;padding:12px;background:#1E2D4E;color:white;border:none;border-radius:8px;font-size:1rem;cursor:pointer;font-weight:500;">
                @if (_loading)
                {
                    <span>Ingresando...</span>
                }
                else
                {
                    <span>Ingresar</span>
                }
            </button>
        </EditForm>
    </div>
</div>

@code {
    private LoginModel _loginModel = new();
    private bool _loading;
    private string? _errorMessage;

    [Inject] private NavigationManager Nav { get; set; } = default!;
    [Inject] private ISupabaseAuthService AuthService { get; set; } = default!;
    [Inject] private SupabaseAuthStateProvider AuthStateProvider { get; set; } = default!;

    private async Task HandleLogin()
    {
        _loading = true;
        _errorMessage = null;

        try
        {
            await AuthService.LoginAsync(_loginModel.Email, _loginModel.Password);
            AuthStateProvider.NotifyUserAuthentication();
            Nav.NavigateTo("/");
        }
        catch
        {
            _errorMessage = "Email o contrasena incorrectos";
        }
        finally
        {
            _loading = false;
        }
    }

    private class LoginModel
    {
        public string Email { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }
}
