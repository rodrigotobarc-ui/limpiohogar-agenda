@inherits LayoutComponentBase
@inject NavigationManager Nav
@inject ISupabaseAuthService AuthService
@inject SupabaseAuthStateProvider AuthStateProvider

<MudLayout>
    <MudMainContent Class="pb-24" Style="background:#F5F7FA;min-height:100vh;">
        <div style="max-width:390px;margin:0 auto;background:white;min-height:100vh;position:relative;">
            <button @onclick="HandleLogout"
                    style="position:absolute;top:12px;right:12px;background:none;border:none;cursor:pointer;color:#9CA3AF;z-index:10;padding:12px;"
                    title="Cerrar sesion">
                <MudIcon Icon="@Icons.Material.Filled.Logout" Size="Size.Large" />
            </button>
            @Body
        </div>
    </MudMainContent>

    <nav style="position:fixed;bottom:0;left:50%;transform:translateX(-50%);width:100%;max-width:390px;background:white;border-top:1px solid #E5E7EB;z-index:50;box-shadow:0 -4px 6px rgba(0,0,0,0.05);padding-bottom:env(safe-area-inset-bottom,0px);">
        <div style="display:flex;justify-content:space-around;align-items:center;height:80px;">
            <a href="/" @onclick:preventDefault @onclick="@(() => Nav.NavigateTo("/"))"
               style="@GetNavStyle("/")">
                <MudIcon Icon="@Icons.Material.Filled.Home" Size="Size.Large" />
                <span style="font-size:0.8rem;">Inicio</span>
            </a>
            <a href="/agenda" @onclick:preventDefault @onclick="@(() => Nav.NavigateTo("/agenda"))"
               style="@GetNavStyle("/agenda")">
                <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Size="Size.Large" />
                <span style="font-size:0.8rem;">Agenda</span>
            </a>
            <a href="/personas" @onclick:preventDefault @onclick="@(() => Nav.NavigateTo("/personas"))"
               style="@GetNavStyle("/personas")">
                <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Large" />
                <span style="font-size:0.8rem;">Personas</span>
            </a>
            <a href="/pagos" @onclick:preventDefault @onclick="@(() => Nav.NavigateTo("/pagos"))"
               style="@GetNavStyle("/pagos")">
                <MudIcon Icon="@Icons.Material.Filled.Payments" Size="Size.Large" />
                <span style="font-size:0.8rem;">Pagos</span>
            </a>
        </div>
    </nav>
</MudLayout>

@code {
    private async Task HandleLogout()
    {
        await AuthService.LogoutAsync();
        AuthStateProvider.NotifyUserLogout();
        Nav.NavigateTo("/login");
    }

    private string CurrentPath => Nav.ToBaseRelativePath(Nav.Uri).Split('?')[0].TrimEnd('/');

    private bool IsActive(string path)
    {
        var current = "/" + CurrentPath;
        if (path == "/") return current == "/";
        if (path == "/personas")
            return current.StartsWith("/personas", StringComparison.OrdinalIgnoreCase)
                || current.StartsWith("/trabajadoras", StringComparison.OrdinalIgnoreCase)
                || current.StartsWith("/clientes", StringComparison.OrdinalIgnoreCase);
        return current.StartsWith(path, StringComparison.OrdinalIgnoreCase);
    }

    private string GetNavStyle(string path)
    {
        var color = IsActive(path) ? "#4CAF9A" : "#9CA3AF";
        return $"display:flex;flex-direction:column;align-items:center;justify-content:center;flex:1;height:100%;color:{color};text-decoration:none;transition:color 0.2s;";
    }
}
